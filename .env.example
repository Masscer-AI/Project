# API KEYS
OPENAI_API_KEY=sk-your-openai-key
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=sk-your-anthropic-key
XAI_API_KEY=xai-your-xai-key
PEXELS_API_KEY=your-pexels-api-key
# Used by Django/Celery for explore_web, URL snapshots, tools (firecrawl-py).
FIRECRAWL_API_KEY=your-firecrawl-api-key
WHATSAPP_GRAPH_API_TOKEN=your-whatsapp-graph-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
# Meta app secret — required to verify X-Hub-Signature-256 on inbound POST webhooks (recommended in production).
WHATSAPP_APP_SECRET=
# Public HTTPS origin of this Django API (no trailing slash). Used for absolute media URLs and for
# Meta WhatsApp webhook registration (admin → WSNumber → "Setup WABA & webhook").
# Django uses API_BASE_URL if set; otherwise API_URL (same as streaming / docker) — you only need one.
API_URL=https://your-tunnel.example.com
BFL_API_KEY=your-bfl-api-key
RUNWAY_API_KEY=your-runway-api-key

RESEND_API_KEY=re_asdasdasd

# CLOUDBEDS INTEGRATION
# Create an app at https://developers.cloudbeds.com to get these credentials.
CLOUDBEDS_CLIENT_ID=your-cloudbeds-client-id
CLOUDBEDS_CLIENT_SECRET=your-cloudbeds-client-secret
# Callback URL registered in your Cloudbeds app settings (must match exactly).
# Defaults to <backend_host>/v1/cloudbeds/callback/ — override for local dev (e.g. ngrok).
CLOUDBEDS_REDIRECT_URI=https://1gm40gnb-8001.use2.devtunnels.ms/v1/cloudbeds/callback/

# REDIS CONFIGURATION
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_NOTIFICATIONS_URL=redis://localhost:6379/2

# DATABASE CONFIGURATION
DB_CONNECTION_STRING=postgres://username:password@localhost:5432/database_name

# CHROMA PREWARM
# Preload default embedding model during backend startup to avoid first-request cold start.
# CHROMA_PREWARM=true
# CHROMA_PREWARM_COLLECTION=masscer_prewarm

# EXTRA ALLOWED HOSTS
# Comma-separated list of extra hosts (e.g. ngrok, tunnels). Added to Django ALLOWED_HOSTS.
# The canonical app host and its tenant subdomains are derived automatically from
# FRONTEND_URL (e.g. app.masscer-ai.com -> also allows .masscer-ai.com + CSRF wildcard).
# Wildcard tenant subdomains for .localhost are enabled by default in settings.py.
# ALLOWED_EXTRA_HOSTS=masscer-ai.ngrok.app,your-tunnel.example.com

# TRUSTED ORIGINS FOR CSRF (must include scheme, used by Django admin/login POSTs)
# CSRF_TRUSTED_ORIGINS=https://masscer-ai.ngrok.app,http://localhost,http://127.0.0.1

# CORS CONFIGURATION
# Include the nginx URL (http://localhost or http://localhost:NGINX_PORT) so Django
# accepts requests proxied through nginx. Also include localhost:5173 for Vite dev server.
CORS_ORIGINS=http://localhost,http://localhost:5173

# Public URL of the frontend/app. Used for embed code, widget script URLs, and
# canonical OAuth redirect URIs when users connect integrations from tenant subdomains.
# Dev example: http://localhost — register {FRONTEND_URL}/v1/integrations/google_drive/callback/
# in Google Cloud Console Authorized redirect URIs.
FRONTEND_URL=

# STRIPE CONFIGURATION
# Get these from https://dashboard.stripe.com/test/apikeys (use test keys for local dev)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Get this by running: stripe listen --forward-to localhost:8000/v1/payments/webhook/
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Price IDs from your Stripe Products (Developers → Products)
STRIPE_PRICE_ORGANIZATION=price_your-organization-plan-price-id
STRIPE_PRODUCT_CREDITS=prod_your-credits-product-id

# GOOGLE OAUTH CONFIGURATION
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized JavaScript origins: canonical app hosts only (e.g. http://localhost, https://app.masscer.ai).
# Tenant subdomains are not registered — Google Sign-In runs on FRONTEND_URL via /auth/google and hands
# the session back via /auth/callback. Also register Authorized redirect URIs:
# {FRONTEND_URL}/auth/google (e.g. http://localhost/auth/google). Drive callback:
# {FRONTEND_URL}/v1/integrations/google_drive/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Required for server-side OAuth (e.g. Google Drive integrations connect flow).
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional explicit override for Drive OAuth callback. If unset, defaults to
# {FRONTEND_URL}/v1/integrations/google_drive/callback/
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}'
GOOGLE_CLOUD_PROJECT=masscer-492023
# Regional Vertex endpoint — used by Veo video generation (generate_video tool).
GOOGLE_CLOUD_LOCATION=us-central1
# Gemini text/chat models (VertexGeminiText, agent loop). Defaults to global in code if unset.
VERTEX_TEXT_LOCATION=global

# VITE CONFIGURATION
# Leave VITE_API_URL empty — the frontend uses relative URLs routed through nginx.
# Set it explicitly only when running the Vite dev server outside of nginx.
VITE_API_URL=
VITE_DEFAULT_ORGANIZATION_ID=my-organization-id
VITE_PUBLIC_TOKEN=your-vite-public-token
# Must match GOOGLE_CLIENT_ID above — used by the frontend Google OAuth button.
# Required when building the streaming Docker image / production bundle (Vite inlines at build time).
# deploy.sh also fills this from SSM /{namePrefix}/providers/GOOGLE_OAUTH_CLIENT_ID after you set
#   pulumi config set masscer-infra:googleOauthClientId "....apps.googleusercontent.com"
# and run pulumi up (same value as here).
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

DJANGO_PORT=8001
FASTAPI_PORT=8003
NGINX_PORT=80
REDIS_PORT=6378
