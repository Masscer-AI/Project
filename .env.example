# API KEYS
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-your-anthropic-key
XAI_API_KEY=xai-your-xai-key
PEXELS_API_KEY=your-pexels-api-key
BRAVE_API_KEY=your-brave-api-key
WHATSAPP_GRAPH_API_TOKEN=your-whatsapp-graph-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
BFL_API_KEY=your-bfl-api-key
RUNWAY_API_KEY=your-runway-api-key

RESEND_API_KEY=re_asdasdasd

# CLOUDBEDS INTEGRATION
# Create an app at https://developers.cloudbeds.com to get these credentials.
CLOUDBEDS_CLIENT_ID=your-cloudbeds-client-id
CLOUDBEDS_CLIENT_SECRET=your-cloudbeds-client-secret
# Callback URL registered in your Cloudbeds app settings (must match exactly).
# Defaults to <backend_host>/v1/cloudbeds/callback/ — override for local dev (e.g. ngrok).
CLOUDBEDS_REDIRECT_URI=https://1gm40gnb-8001.use2.devtunnels.ms/v1/cloudbeds/callback/

# REDIS CONFIGURATION
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1
REDIS_NOTIFICATIONS_URL=redis://localhost:6379/2

# DATABASE CONFIGURATION
DB_CONNECTION_STRING=postgres://username:password@localhost:5432/database_name

# CHROMA PREWARM
# Preload default embedding model during backend startup to avoid first-request cold start.
# CHROMA_PREWARM=true
# CHROMA_PREWARM_COLLECTION=masscer_prewarm

# EXTRA ALLOWED HOSTS
# Comma-separated list of extra hosts (e.g. ngrok, tunnels). Added to Django ALLOWED_HOSTS.
# ALLOWED_EXTRA_HOSTS=masscer-ai.ngrok.app,your-tunnel.example.com

# TRUSTED ORIGINS FOR CSRF (must include scheme, used by Django admin/login POSTs)
# CSRF_TRUSTED_ORIGINS=https://masscer-ai.ngrok.app,http://localhost,http://127.0.0.1

# CORS CONFIGURATION
# Include the nginx URL (http://localhost or http://localhost:NGINX_PORT) so Django
# accepts requests proxied through nginx. Also include localhost:5173 for Vite dev server.
CORS_ORIGINS=http://localhost,http://localhost:5173

# WIDGET URL (production)
# Public URL of the frontend/app. Used for embed code and widget script URLs.
# Set in production (e.g. https://app.masscer.com). Leave empty for localhost fallback.
FRONTEND_URL=

# VITE CONFIGURATION
# Leave VITE_API_URL empty — the frontend uses relative URLs routed through nginx.
# Set it explicitly only when running the Vite dev server outside of nginx.
VITE_API_URL=
VITE_DEFAULT_ORGANIZATION_ID=my-organization-id
VITE_PUBLIC_TOKEN=your-vite-public-token

DJANGO_PORT=8001
FASTAPI_PORT=8003
NGINX_PORT=80
REDIS_PORT=6378