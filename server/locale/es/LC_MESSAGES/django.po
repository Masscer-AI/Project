msgstr "Introduce un amount_usd positivo para recargar el monedero."

msgid "Wallet credited with %(amount)s USD equivalent."
msgstr "Monedero acreditado con el equivalente a %(amount)s USD."

msgid "Wallet recharge requires at least one active Masscer subscription."
msgstr "La recarga del monedero requiere al menos una suscripción Masscer activa."

msgid "Use no more than two decimal places when registering a payment."
msgstr "Usa máximo dos decimales al registrar un pago."

msgid "Payment note is required when registering a payment."
msgstr "La nota del pago es obligatoria al registrar un pago."

msgid "Registered wallet recharge as a payment."
msgstr "Recarga del monedero registrada como pago."

