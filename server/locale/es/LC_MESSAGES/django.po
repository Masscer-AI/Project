msgid_plural "Stripe reported missing subscription id(s); cleared stale stripe_subscription_id from %(count)d Masscer rows."
msgstr[0] "Stripe informó ids de suscripción faltantes; se limpió el stripe_subscription_id obsoleto de una fila de Masscer."
msgstr[1] "Stripe informó ids de suscripción faltantes; se limpió el stripe_subscription_id obsoleto de %(count)d filas de Masscer."

msgid "This Stripe subscription no longer exists (removed or expired). Cleared stale stripe_subscription_id from one Masscer row."
msgid_plural "This Stripe subscription no longer exists (removed or expired). Cleared stale stripe_subscription_id from %(count)d Masscer rows."
msgstr[0] "Esta suscripción de Stripe ya no existe (eliminada o caducada). Se limpió el stripe_subscription_id obsoleto de una fila de Masscer."
msgstr[1] "Esta suscripción de Stripe ya no existe (eliminada o caducada). Se limpió el stripe_subscription_id obsoleto de %(count)d filas de Masscer."

msgid "Marked one previous Masscer subscription row as cancelled; created new manual subscription."
